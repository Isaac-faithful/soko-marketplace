# Keep real keys out of source control. Use Paystack test keys first.
PAYMENTS_PROVIDER=development
PAYSTACK_SECRET_KEY=sk_test_replace_me
NODE_ENV=development
APP_BASE_URL=http://localhost:4173
# On a hosted server, point this at the mounted persistent disk (for example /var/data).
SOKO_DATA_DIR=./data
# Set to 24 on production to create a daily backup on the persistent disk.
BACKUP_INTERVAL_HOURS=0
# Use a long, random secret and back it up securely. Changing it makes existing identity files unreadable.
DOCUMENT_ENCRYPTION_KEY=replace_with_a_long_random_secret
# HMAC secret for carrier delivery-status webhooks.
CARRIER_WEBHOOK_SECRET=replace_with_a_carrier_webhook_secret
# Leave as development to keep email in the simulated outbox. Use resend in production.
EMAIL_PROVIDER=development
RESEND_API_KEY=re_replace_me
EMAIL_FROM=Soko <notifications@example.com>
# Keep automatic delivery off during testing; use the admin flush endpoint for a controlled send.
EMAIL_AUTO_FLUSH=false
